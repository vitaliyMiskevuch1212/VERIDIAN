# ============================================
# VERIDIAN — Environment Variables
# Copy this file to .env and fill in your keys
# ============================================

# --- AI Provider Keys ---
# Groq API keys (4-key rotation for rate limit handling)
GROQ_API_KEY_1=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_2=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_3=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_4=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini (fallback when all Groq keys exhausted)
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Data Source API Keys ---
# NewsAPI.org — free tier: 100 requests/day
NEWS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ACLED — Armed Conflict Location & Event Data
ACLED_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NASA FIRMS — Active fire / wildfire data
NASA_FIRMS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mapbox — 3D map tiles (optional, for Map2D component)
MAPBOX_TOKEN=pk.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ExchangeRate API — forex rates
EXCHANGE_RATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare Radar — (optional) network threat intelligence
CLOUDFLARE_RADAR_KEY=cfut_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Database ---
# MongoDB Atlas connection string
MONGODB_URI=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# --- Server ---
PORT=5000
# Deployed frontend URL (for CORS — no trailing slash)
CLIENT_URL=https://your-app-name.vercel.app
